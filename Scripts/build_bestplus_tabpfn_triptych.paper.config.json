{
  "labels": {
    "method_aliases": {
      "RandomCV": "RandCV",
      "Extrapolation": "Extra",
      "SparseXcluster": "SparseX\ncluster",
      "SparseXsingle": "SparseX\nsingle",
      "SparseYcluster": "SparseY\ncluster",
      "SparseYsingle": "SparseY\nsingle"
    },
    "series_aliases": {
      "BERT-best": "BERT-best",
      "Traditional-best": "Trad-best",
      "TabPFN-2.5-Plus-Numeric": "TabPFN-num",
      "TabPFN-2.5-Plus-Text": "TabPFN-text",
      "gpt-5.4": "gpt-5.4"
    },
    "summary_xlabel": "OOD split",
    "baseline_xlabel": "OOD split",
    "rank_xlabel": "OOD split",
    "summary_ylabel": "OOD-test MAE",
    "baseline_ylabel": "",
    "rank_ylabel": ""
  },
  "selection": {
    "family_best_metric": "plot_test_mae",
    "family_best_metric_direction": "asc",
    "family_best_std_metric": "summary_test_mae_std",
    "family_best_std_metric_direction": "asc",
    "family_best_tiebreak_metric": "summary_test_r2",
    "family_best_tiebreak_metric_direction": "desc"
  },
  "display": {
    "summary_metric": "plot_test_mae",
    "summary_std_metric": "summary_test_mae_std",
    "baseline_metric": "plot_test_mae",
    "baseline_reference_label": "Traditional-best",
    "baseline_relative_mode": "improvement_pct",
    "baseline_better_direction": "lower",
    "rank_metric": "plot_test_mae",
    "rank_metric_direction": "asc",
    "rank_std_metric": "summary_test_mae_std",
    "rank_std_metric_direction": "asc",
    "rank_tiebreak_metric": "summary_test_r2",
    "rank_tiebreak_metric_direction": "desc",
    "baseline_colorbar_label": "Delta MAE vs Trad-best (%)",
    "rank_colorbar_label": "Rank (1=best)"
  },
  "panels": {
    "summary": {
      "enabled": true
    },
    "baseline": {
      "enabled": true
    },
    "rank": {
      "enabled": true
    }
  },
  "figure": {
    "context": "paper",
    "font_scale": 0.9,
    "figsize": [
      15.2,
      4.9
    ],
    "panel_width_ratios": {
      "summary": 2.35,
      "baseline": 1.15,
      "rank": 1.0
    },
    "wspace": 0.22,
    "bar_width": 0.16,
    "bar_capsize": 2,
    "bar_edgecolor": "black",
    "bar_linewidth": 0.6,
    "summary_zero_line": false,
    "summary_show_errorbars": false,
    "summary_show_legend": true,
    "summary_show_value_labels": false,
    "summary_value_label_fmt": ".1f",
    "summary_value_label_fontsize": 6,
    "summary_value_label_padding": 2,
    "summary_ylim": null,
    "summary_xtick_rotation": 0,
    "heatmap_xtick_rotation": 0,
    "heatmap_ytick_rotation": 0,
    "dpi": 400,
    "legend_title": "Series",
    "legend_loc": "upper center",
    "legend_bbox_to_anchor": [
      0.5,
      1.01
    ],
    "legend_ncol": 2,
    "legend_fontsize": 7.5,
    "legend_title_fontsize": 7.5,
    "legend_frameon": true,
    "heatmap_linewidths": 0.4,
    "linecolor": "white",
    "heatmap_annot_fontsize": 7,
    "heatmap_annot_color": "black",
    "baseline_annotation_fmt": ".1f",
    "baseline_show_colorbar": true,
    "baseline_cbar_shrink": 0.92,
    "baseline_heatmap_cmap": "RdBu",
    "baseline_heatmap_center": 0.0,
    "baseline_vmin": -120,
    "baseline_vmax": 20,
    "rank_annotation_fmt": ".0f",
    "rank_show_colorbar": true,
    "rank_cmap": "Blues_r",
    "rank_vmin": 1,
    "rank_vmax": 5,
    "title_fontsize": 11.5,
    "panel_title_fontsize": 10.0,
    "axis_label_fontsize": 9.0,
    "tick_label_fontsize": 8.0,
    "show_suptitle": true,
    "suptitle_y": 0.985,
    "tight_layout_pad": 0.55,
    "summary_title": "MAE",
    "baseline_title": "Delta MAE vs Trad-best",
    "rank_title": "Rank by OOD-test MAE",
    "save_facecolor": "white",
    "save_transparent": false,
    "bbox_inches": "tight"
  },
  "output": {
    "title_template": "{alloy_family} | {dataset_name} | {property}",
    "formats": [
      "png",
      "pdf"
    ]
  }
}
